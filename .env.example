# Skopiuj do .env i uzupełnij własnymi wartościami. NIE commituj .env (jest w .gitignore).

# ── Agent (model językowy przez API zgodne z OpenAI, np. build.nvidia.com) ──
# Klucz z https://build.nvidia.com  (nvapi-...). Czytany TYLKO przez server/agent.mjs.
LOKALIO_API_KEY=
# Endpoint zgodny z OpenAI (domyślnie NVIDIA):
LOKALIO_API_BASE=https://integrate.api.nvidia.com/v1
# Model, np. meta/llama-3.3-70b-instruct | meta/llama-3.1-8b-instruct | nvidia/llama-3.1-nemotron-70b-instruct
LOKALIO_MODEL=meta/llama-3.3-70b-instruct
LOKALIO_AGENT_PORT=8787

# ── Supabase (konta + baza) ──
# Z panelu projektu Supabase → Settings → API. Anon key jest publiczny (chroni go RLS).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Mapbox (mapa) ──
# Token publiczny (pk....) z https://account.mapbox.com → Tokens. Można (warto) ograniczyć do swojej domeny.
# Pusty = mapa działa po staremu na Leaflet (CARTO). Ustawiony = Mapbox GL JS.
VITE_MAPBOX_TOKEN=
